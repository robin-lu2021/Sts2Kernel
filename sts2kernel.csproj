<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>sts2kernel</AssemblyName>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <TargetFramework>net9.0</TargetFramework>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <LangVersion>13.0</LangVersion>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="kernel\**\*.cs" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="SmartFormat">
      <HintPath>.godot\mono\temp\bin\Debug\SmartFormat.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="System.IO.Hashing">
      <HintPath>.godot\mono\temp\bin\Debug\System.IO.Hashing.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>
</Project>
